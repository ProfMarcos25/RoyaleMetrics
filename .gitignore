# =====================================================
# Royle Metrics — .gitignore
# =====================================================

# ---------------------------
# Variáveis de ambiente
# NUNCA versionar o .env real
# ---------------------------
.env
*.env
!.env.example

# ---------------------------
# Ambiente virtual Python
# ---------------------------
.venv/
venv/
env/
ENV/

# ---------------------------
# Cache do Python
# ---------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ---------------------------
# Distribuição / Build
# ---------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/

# ---------------------------
# Pytest / Coverage
# ---------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ---------------------------
# Logs
# ---------------------------
*.log
logs/

# ---------------------------
# Banco de dados local
# ---------------------------
*.sqlite3
*.db

# ---------------------------
# VS Code
# ---------------------------
.vscode/
*.code-workspace

# ---------------------------
# Sistema operacional
# ---------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------
# Jupyter Notebooks
# ---------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------
# Mypy / Pyright
# ---------------------------
.mypy_cache/
.pyright/
pyrightconfig.json

# ---------------------------
# Dados sensíveis / gerados
# ---------------------------
data/exports/
*.csv
*.xlsx
